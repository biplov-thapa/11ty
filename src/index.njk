---
title: "My Beautiful Timeline"
layout: "base.njk"
---

<!-- ── FLOATING PETALS ── -->
<div class="petal-container" id="petalContainer"></div>

<!-- ── HERO ── -->
<section class="hero">
  <!-- Hero Background SVG -->
  <svg class="hero-bg-svg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <!-- Watercolor wash blobs -->
    <ellipse cx="200" cy="180" rx="300" ry="200" fill="rgba(249,228,232,0.5)" />

    <!-- Botanical vines top-left -->
    <g transform="translate(0,0)" opacity="0.55">
      <path d="M30 0 Q 60 80 20 160 Q -10 240 50 320" stroke="#A8C5A0" stroke-width="2.5" fill="none" stroke-linecap="round"/>
      <circle cx="50" cy="100" r="18" fill="rgba(168,197,160,0.3)" />
      <circle cx="22" cy="200" r="14" fill="rgba(249,228,232,0.5)" />
      <circle cx="52" cy="290" r="20" fill="rgba(237,224,245,0.4)" />
      <!-- Small leaves -->
      <ellipse cx="65" cy="100" rx="14" ry="8" fill="rgba(168,197,160,0.5)" transform="rotate(-30 65 100)"/>
      <ellipse cx="8" cy="200" rx="12" ry="7" fill="rgba(168,197,160,0.5)" transform="rotate(40 8 200)"/>
      <!-- Flower -->
      <circle cx="52" cy="290" r="8" fill="rgba(232,160,176,0.8)" />
      <circle cx="52" cy="278" r="5" fill="rgba(249,228,232,0.9)" />
      <circle cx="63" cy="283" r="5" fill="rgba(249,228,232,0.9)" />
      <circle cx="41" cy="283" r="5" fill="rgba(249,228,232,0.9)" />
    </g>

    <!-- Botanical vines top-right -->
    <g transform="translate(1440,0) scale(-1,1)" opacity="0.55">
      <path d="M30 0 Q 60 80 20 160 Q -10 240 50 320" stroke="#A8C5A0" stroke-width="2.5" fill="none" stroke-linecap="round"/>
      <circle cx="50" cy="100" r="18" fill="rgba(168,197,160,0.3)" />
      <circle cx="22" cy="200" r="14" fill="rgba(249,228,232,0.5)" />
      <circle cx="52" cy="290" r="20" fill="rgba(237,224,245,0.4)" />
      <ellipse cx="65" cy="100" rx="14" ry="8" fill="rgba(168,197,160,0.5)" transform="rotate(-30 65 100)"/>
      <ellipse cx="8" cy="200" rx="12" ry="7" fill="rgba(168,197,160,0.5)" transform="rotate(40 8 200)"/>
      <circle cx="52" cy="290" r="8" fill="rgba(232,160,176,0.8)" />
      <circle cx="52" cy="278" r="5" fill="rgba(249,228,232,0.9)" />
      <circle cx="63" cy="283" r="5" fill="rgba(249,228,232,0.9)" />
      <circle cx="41" cy="283" r="5" fill="rgba(249,228,232,0.9)" />
    </g>

    <!-- Scattered stars / sparkles -->
    <g fill="rgba(200,149,106,0.45)">
      <polygon points="180,80 184,93 197,93 187,101 191,114 180,107 169,114 173,101 163,93 176,93" transform="scale(0.5) translate(120,80)"/>
      <polygon points="180,80 184,93 197,93 187,101 191,114 180,107 169,114 173,101 163,93 176,93" transform="scale(0.35) translate(3200,300)"/>
      <polygon points="180,80 184,93 197,93 187,101 191,114 180,107 169,114 173,101 163,93 176,93" transform="scale(0.4) translate(2000,1600)"/>
    </g>

    <!-- Floating hearts background -->
    <g opacity="0.15">
      <path d="M350 500 C350 490 340 480 330 490 C320 480 310 490 310 500 C310 510 330 525 350 535 C370 525 390 510 390 500 C390 490 380 480 370 490 C360 480 350 490 350 500Z" fill="#E8A0B0" transform="scale(0.6) translate(300,200)"/>
      <path d="M350 500 C350 490 340 480 330 490 C320 480 310 490 310 500 C310 510 330 525 350 535 C370 525 390 510 390 500 C390 490 380 480 370 490 C360 480 350 490 350 500Z" fill="#C3A8D8" transform="scale(0.4) translate(2700,800)"/>
    </g>
  </svg>

  <div class="hero-title-wrap">
    <h1 class="hero-title">Our <span>Story</span></h1>
    
    <div class="hero-heart-divider">
      <div class="line"></div>
      <!-- Heart SVG -->
      <svg viewBox="0 0 24 24" height="24" width="24"><path fill="#E8A0B0" d="M12,21.35L10.55,20.03C5.4,15.36 2,12.27 2,8.5C2,5.41 4.41,3 7.5,3C9.24,3 10.91,3.81 12,5.08C13.09,3.81 14.76,3 16.5,3C19.59,3 22,5.41 22,8.5C22,12.27 18.6,15.36 13.45,20.03L12,21.35Z"></path></svg>
      <div class="line right"></div>
    </div>
    
    <p class="hero-eyebrow">✦ This is a place for Eric & I to share our latest photos, news, and interests with our friends and relatives. We hope you enjoy the site! ✦</p>
  </div>

  <div class="scroll-hint">
    <span>scroll through our memories</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<!-- ── TIMELINE ── -->
<section class="timeline-section">
  <div class="section-header">
    <span class="section-label">chapter by chapter</span>
    <h2 class="section-title">Our Timeline</h2>
  </div>

  <ul class="timeline" id="timeline">
    {% for event in collections.event %}
      <li class="entry" data-index="{{ loop.index0 }}">
        <div class="card">
          <div class="card-date">
            <span class="card-emoji">{{ event.data.emoji or '🌸' }}</span>
            {{ event.data.month }}
            <span class="card-year">{{ event.data.year }}</span>
          </div>

          <div class="card-divider"></div>

          <p class="card-desc">{{ event.data.highlight }}</p>

          <div class="card-image">
            {% if event.data.img %}
              <img src="{{ event.data.img }}" alt="{{ event.data.month }}" loading="lazy">
            {% else %}
              <svg width="52" height="52" viewBox="0 0 52 52" style="opacity:0.4;">
                <path d="M26 46C26 46 4 32 4 16C4 9.37 9.37 4 16 4C19.9 4 23.3 5.97 26 9.03C28.7 5.97 32.1 4 36 4C42.63 4 48 9.37 48 16C48 32 26 46 26 46Z" fill="#E8A0B0"/>
              </svg>
              <span class="image-placeholder-label">
                Add your favourite photo<br>from {{ event.data.month }}
              </span>
            {% endif %}
          </div>

          <div class="card-corner-decor"></div>
        </div>

        <div class="entry-spacer"></div>
        <div class="entry-dot" title="{{ event.data.month }}"></div>
      </li>
    {% endfor %}
  </ul>
</section>

<script>
// ── RENDER TIMELINE ───────────────────────────────────────────────────────────
function heartSVG(size = 20, color = '#E8A0B0') {
  return `<svg width="${size}" height="${Math.round(size*0.85)}" viewBox="0 0 20 17" fill="none"><path d="M10 16C10 16 1 10 1 5C1 2.79 2.79 1 5 1C6.5 1 7.8 1.75 8.75 2.9C9.7 1.75 11 1 12.5 1C14.71 1 16.5 2.79 16.5 5C16.5 10 10 16 10 16Z" fill="${color}"/></svg>`;
}

function renderTimeline() {
  const entries = document.querySelectorAll('#timeline .entry');

  entries.forEach((entry, i) => {
    // Alternate left / right
    entry.classList.add(i % 2 === 0 ? 'left' : 'right');

    // Dot icon rotation
    const dot = entry.querySelector('.entry-dot');
    const DOT_ICONS = ['🌸', '💖', '✨'];
    dot.innerHTML = "<span>" + DOT_ICONS[i % DOT_ICONS.length] + "</span>";

    // Corner decoration
    const corner = entry.querySelector('.card-corner-decor');
    corner.innerHTML = heartSVG(14) + heartSVG(14) + heartSVG(14);
  });

  observeEntries(entries);
}

// ── SCROLL ANIMATION ──────────────────────────────────────────────────────────
function observeEntries() {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.entry').forEach(el => observer.observe(el));
}

// ── PETALS ────────────────────────────────────────────────────────────────────
function createPetals() {
  const container = document.getElementById('petalContainer');
  const petalSVGs = [
    `<svg viewBox="0 0 20 24" xmlns="http://www.w3.org/2000/svg"><ellipse cx="10" cy="12" rx="8" ry="11" fill="rgba(249,228,232,0.8)" transform="rotate(-20 10 12)"/></svg>`,
    `<svg viewBox="0 0 20 24" xmlns="http://www.w3.org/2000/svg"><ellipse cx="10" cy="12" rx="7" ry="10" fill="rgba(237,224,245,0.75)" transform="rotate(15 10 12)"/></svg>`,
    `<svg viewBox="0 0 20 24" xmlns="http://www.w3.org/2000/svg"><ellipse cx="10" cy="12" rx="6" ry="9" fill="rgba(240,213,184,0.7)" transform="rotate(-10 10 12)"/></svg>`,
    `<svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg"><path d="M8 14C8 14 1 9 1 5C1 2.79 2.79 1 5 1C6.38 1 7.6 1.66 8 2.5C8.4 1.66 9.62 1 11 1C13.21 1 15 2.79 15 5C15 9 8 14 8 14Z" fill="rgba(232,160,176,0.5)"/></svg>`,
  ];

  for (let i = 0; i < 18; i++) {
    const petal = document.createElement('div');
    petal.className = 'petal';
    const size = 12 + Math.random() * 20;
    petal.style.cssText = `
      left: ${Math.random() * 100}%;
      width: ${size}px;
      height: ${size * 1.3}px;
      animation-duration: ${12 + Math.random() * 18}s;
      animation-delay: ${Math.random() * 20}s;
    `;
    petal.innerHTML = petalSVGs[Math.floor(Math.random() * petalSVGs.length)];
    container.appendChild(petal);
  }
}

// ── CURSOR SPARKLE ────────────────────────────────────────────────────────────
const sparkColors = ['#E8A0B0','#C3A8D8','#F0D5B8','#A8C5A0','#9B4F6A'];
let lastSparkle = 0;

document.addEventListener('mousemove', (e) => {
  if (Date.now() - lastSparkle < 60) return;
  lastSparkle = Date.now();

  const s = document.createElement('div');
  s.className = 'sparkle';
  const angle = Math.random() * 360;
  const dist = 20 + Math.random() * 30;
  s.style.cssText = `
    left: ${e.clientX}px;
    top: ${e.clientY}px;
    background: ${sparkColors[Math.floor(Math.random() * sparkColors.length)]};
    --dx: ${Math.cos(angle) * dist}px;
    --dy: ${Math.sin(angle) * dist}px;
    width: ${4 + Math.random() * 6}px;
    height: ${4 + Math.random() * 6}px;
  `;
  document.body.appendChild(s);
  setTimeout(() => s.remove(), 800);
});

createPetals();
renderTimeline();
</script>

